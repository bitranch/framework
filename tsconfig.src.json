{
	"compilerOptions": {
		"declaration": true,
		"downlevelIteration": true,
		"experimentalDecorators": true,
		"ignoreDeprecations": "6.0",
		"jsx": "react",
		"jsxFactory": "tsx",
		"lib": [
			"dom",
			"es5",
			"es2015.core",
			"es2015.iterable",
			"es2015.promise",
			"es2015.symbol",
			"es2015.symbol.wellknown",
			"es2015.proxy",
			"ES2019.Array"
		],
		"module": "umd",
		"moduleResolution": "node10",
		"noUnusedLocals": false,
		"outDir": "dist/umd",
		"rootDir": "./src",
		"removeComments": false,
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"target": "es5",
		"types": ["node"]
	},
	"include": [
		"./src/**/*.ts",
		"./src/**/*.tsx"
	]
}
